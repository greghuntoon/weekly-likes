{
  "name": "weekly-likes",
  "version": "1.0.0",
  "description": "Local-first CLI to create weekly Spotify playlists from liked songs",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "auth": "tsc && node dist/index.js auth",
